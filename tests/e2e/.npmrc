# pnpm/npm config local to the E2E suite.
#
# tauri-driver expects the OS-native WebDriver binaries (`webkit2gtk-driver` on
# Linux, `safaridriver` on macOS, `msedgedriver.exe` on Windows) to be reachable
# via PATH. Override the lookup directory here if your install location differs.
# Leaving the value blank falls back to the platform default.
tauri-driver-binary-dir=

# Prevent pnpm from auto-installing peer deps when running inside this directory.
auto-install-peers=true
strict-peer-dependencies=false
